VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# API URL for production frontend build.
# Leave empty when frontend and backend are served from same domain.
VITE_API_URL=

# App auth secret (required in production)
SERVER_JWT_SECRET=change-me-to-a-long-random-secret

# Gmail SMTP for OTP
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Preferred on Render Free (SMTP ports are blocked on Free plans):
# https://render.com/docs/free#free-web-services
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM=Your App <onboarding@yourdomain.com>

# Payments
PAYSTACK_SECRET_KEY=sk_test_...
FLW_SECRET_KEY=FLWSECK_TEST-...

# Optional runtime controls
DISABLE_MARKET_WS=1

# Notes:
# - Copy this file to `.env` and fill in values before running locally.
# - Do NOT commit your real `.env` file to source control.
